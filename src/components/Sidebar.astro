---
import { SOCIALS } from "@/constants";
import LinkButton from "./LinkButton.astro";
import IconRss from "@/assets/icons/IconRss.svg";

interface Props {
  koHref?: string;
  enHref?: string;
}

const { koHref: koHrefProp, enHref: enHrefProp } = Astro.props;

const pathname = Astro.url.pathname;
const isEnglishPage =
  pathname === "/en" ||
  pathname === "/en/" ||
  pathname.startsWith("/en/");

// Naive URL swap between languages.
// Post details override with explicit props when the counterpart exists.
const defaultKoHref = isEnglishPage
  ? pathname.replace(/^\/en(\/|$)/, "/") || "/"
  : pathname;
const defaultEnHref = isEnglishPage
  ? pathname
  : pathname === "/"
    ? "/en/"
    : `/en${pathname}`;

const koHref = koHrefProp ?? defaultKoHref;
const enHref = enHrefProp ?? defaultEnHref;

const currentLang: "ko" | "en" = isEnglishPage ? "en" : "ko";
---

<aside class="sidebar">
  <div class="sidebar-inner">
    <img
      src="/profile.jpg"
      alt="박효인"
      class="sidebar-profile"
      width="120"
      height="120"
      loading="lazy"
    />
    <div class="sidebar-identity">
      <div class="sidebar-name">박효인</div>
      <div class="sidebar-name-en">Park Hyoin</div>
    </div>
    <p class="sidebar-tagline">
      {currentLang === "en"
        ? "Embedded SW · AI Agent · Vibe coding"
        : "임베디드 SW · AI Agent · Vibe coding"}
    </p>
    <div class="sidebar-lang-switch" role="group" aria-label="Language">
      <a
        href={koHref}
        class:list={[
          "sidebar-lang-btn",
          { "sidebar-lang-active": currentLang === "ko" },
        ]}
        aria-current={currentLang === "ko" ? "true" : undefined}
        aria-label="한국어로 보기"
      >
        KO
      </a>
      <a
        href={enHref}
        class:list={[
          "sidebar-lang-btn",
          { "sidebar-lang-active": currentLang === "en" },
        ]}
        aria-current={currentLang === "en" ? "true" : undefined}
        aria-label="View in English"
      >
        EN
      </a>
    </div>
    <div class="sidebar-socials">
      {
        SOCIALS.map(social => (
          <LinkButton
            href={social.href}
            title={social.linkTitle}
            class="sidebar-social-link"
          >
            <social.icon class="sidebar-social-icon" />
            <span class="sr-only">{social.linkTitle}</span>
          </LinkButton>
        ))
      }
      <LinkButton
        href="/rss.xml"
        title={currentLang === "en" ? "Subscribe to RSS feed" : "RSS 피드 구독"}
        class="sidebar-social-link"
      >
        <IconRss class="sidebar-social-icon" />
        <span class="sr-only">
          {currentLang === "en" ? "Subscribe to RSS feed" : "RSS 피드 구독"}
        </span>
      </LinkButton>
    </div>
  </div>
</aside>

<style>
  .sidebar {
    width: 100%;
    padding: 1.5rem 0 1rem 0;
  }
  .sidebar-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.6rem;
  }
  .sidebar-profile {
    width: 120px;
    height: 120px;
    border-radius: 9999px;
    object-fit: cover;
    border: 2px solid var(--border);
  }
  .sidebar-identity {
    margin-top: 0.25rem;
  }
  .sidebar-name {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--foreground);
  }
  .sidebar-name-en {
    font-size: 0.85rem;
    opacity: 0.75;
    letter-spacing: 0.02em;
  }
  .sidebar-tagline {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    max-width: 200px;
    margin: 0;
  }
  .sidebar-lang-switch {
    display: inline-flex;
    margin-top: 0.5rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.03em;
  }
  .sidebar-lang-btn {
    padding: 0.25rem 0.6rem;
    color: var(--muted);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .sidebar-lang-btn + .sidebar-lang-btn {
    border-left: 1px solid var(--border);
  }
  .sidebar-lang-btn:hover {
    background: var(--accent-bg);
    color: var(--foreground);
  }
  .sidebar-lang-active {
    background: var(--foreground);
    color: var(--background);
  }
  .sidebar-lang-active:hover {
    background: var(--foreground);
    color: var(--background);
  }
  .sidebar-socials {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.25rem;
    margin-top: 0.4rem;
  }
  .sidebar-social-link {
    padding: 0.4rem;
    border-radius: 6px;
  }
  .sidebar-social-link:hover {
    background: var(--accent-bg);
  }
  .sidebar-social-icon {
    display: inline-block;
    width: 1.1rem;
    height: 1.1rem;
    stroke: currentColor;
    fill: transparent;
    stroke-width: 2;
    opacity: 0.85;
  }

  /* Desktop: sticky sidebar */
  @media (min-width: 768px) {
    .sidebar {
      padding: 2rem 0;
      position: sticky;
      top: 1rem;
      align-self: start;
    }
    .sidebar-inner {
      align-items: flex-start;
      text-align: left;
    }
    .sidebar-socials {
      justify-content: flex-start;
    }
    .sidebar-tagline {
      max-width: none;
    }
  }
</style>
