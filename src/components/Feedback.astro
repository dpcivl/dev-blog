---
type Props = {
  lang: "ko" | "en";
  postTitle: string;
};

const { lang, postTitle } = Astro.props;

const emailAddress = "dpcivl713@gmail.com";

const subject =
  lang === "en"
    ? `Feedback: ${postTitle}`
    : `[블로그 피드백] ${postTitle}`;

const issueHref =
  `https://github.com/dpcivl/dev-blog/issues/new?title=${encodeURIComponent(subject)}`;

const copy =
  lang === "en"
    ? {
        intro: "Questions, comments, or a different take — welcome.",
        emailAriaLabel: "Copy email address",
        copyHint: "Click to copy",
        copied: "Copied!",
        openIssue: "Open a GitHub Issue",
      }
    : {
        intro: "질문 · 코멘트 · 다른 시각 환영합니다.",
        emailAriaLabel: "이메일 주소 복사",
        copyHint: "클릭하면 복사",
        copied: "복사됐어요!",
        openIssue: "GitHub Issue 열기",
      };
---

<aside class="feedback-cta" aria-label={lang === "en" ? "Feedback" : "피드백"}>
  <p class="feedback-intro">{copy.intro}</p>

  <div class="feedback-actions">
    <button
      type="button"
      class="feedback-email-pill"
      data-email={emailAddress}
      data-copied-label={copy.copied}
      aria-label={copy.emailAriaLabel}
      title={copy.copyHint}
    >
      <span class="feedback-email-text">{emailAddress}</span>
      <span class="feedback-email-icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="feedback-icon-copy"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path
            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
          ></path>
        </svg>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="feedback-icon-check"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </span>
    </button>
    <a
      href={issueHref}
      target="_blank"
      rel="noopener noreferrer"
      class="feedback-btn"
    >
      <span class="feedback-icon" aria-hidden="true">↗</span>
      <span>{copy.openIssue}</span>
    </a>
  </div>
</aside>

<style>
  .feedback-cta {
    margin: 1.75rem 0 1.5rem 0;
    padding: 1rem 1.25rem;
    background: var(--accent-bg);
    border: 1px dashed var(--border);
    border-radius: 10px;
  }
  .feedback-intro {
    margin: 0 0 0.75rem 0;
    font-size: 0.9rem;
    color: var(--foreground);
    line-height: 1.5;
  }
  .feedback-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }

  /* 이메일 pill — 클릭 = 복사 */
  .feedback-email-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.8rem;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: inherit;
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      border-color 0.15s ease,
      color 0.15s ease,
      background 0.2s ease,
      transform 0.15s ease;
  }
  .feedback-email-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }
  .feedback-email-pill:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .feedback-email-text {
    font-variant-numeric: tabular-nums;
  }
  .feedback-email-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }
  .feedback-email-pill:hover .feedback-email-icon {
    opacity: 1;
  }
  .feedback-icon-check {
    display: none;
  }

  /* Copied 상태 */
  .feedback-email-pill.is-copied {
    background: var(--accent);
    color: var(--background);
    border-color: var(--accent);
    transform: none;
  }
  .feedback-email-pill.is-copied .feedback-icon-copy {
    display: none;
  }
  .feedback-email-pill.is-copied .feedback-icon-check {
    display: inline-block;
  }
  .feedback-email-pill.is-copied .feedback-email-icon {
    opacity: 1;
  }

  /* GitHub Issue 링크 */
  .feedback-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    transition:
      border-color 0.15s ease,
      color 0.15s ease,
      transform 0.15s ease;
  }
  .feedback-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }
  .feedback-icon {
    font-size: 0.95rem;
    line-height: 1;
  }
</style>

<script>
  function initFeedbackCopy() {
    const pills =
      document.querySelectorAll<HTMLButtonElement>(".feedback-email-pill");
    pills.forEach(pill => {
      if (pill.dataset.bound === "1") return;
      pill.dataset.bound = "1";
      const originalText = pill
        .querySelector<HTMLElement>(".feedback-email-text")
        ?.textContent ?? "";

      pill.addEventListener("click", async () => {
        const email = pill.dataset.email ?? "";
        const copiedLabel = pill.dataset.copiedLabel ?? "";
        const textEl = pill.querySelector<HTMLElement>(".feedback-email-text");
        if (!email || !textEl) return;

        try {
          await navigator.clipboard.writeText(email);
          textEl.textContent = copiedLabel;
          pill.classList.add("is-copied");
          window.setTimeout(() => {
            textEl.textContent = originalText;
            pill.classList.remove("is-copied");
          }, 1500);
        } catch {
          // Clipboard API 실패 (비-secure context 등). 이메일 텍스트 selection 폴백.
          const range = document.createRange();
          range.selectNodeContents(textEl);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
      });
    });
  }

  initFeedbackCopy();
  document.addEventListener("astro:page-load", initFeedbackCopy);
</script>
