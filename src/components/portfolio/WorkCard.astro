---
import type { CollectionEntry } from "astro:content";

type Props = {
  project: CollectionEntry<"portfolio">;
};

const { project } = Astro.props;
const {
  title,
  period,
  role,
  company,
  techStack,
  description,
  gallery,
  responsibilities,
  outcomes,
} = project.data;
---

<article class="card">
  <h3 class="text-xl font-semibold mb-4">{title}</h3>

  <dl class="card-fields">
    {
      company && (
        <div class="field-row">
          <dt>회사</dt>
          <dd>{company}</dd>
        </div>
      )
    }
    <div class="field-row">
      <dt>기간</dt>
      <dd>{period}</dd>
    </div>
    {
      role && (
        <div class="field-row">
          <dt>역할</dt>
          <dd>{role}</dd>
        </div>
      )
    }
    {
      techStack.length > 0 && (
        <div class="field-row">
          <dt>기술 스택</dt>
          <dd>
            {techStack.map(t => <span class="tech-badge">{t}</span>)}
          </dd>
        </div>
      )
    }
    <div class="field-row">
      <dt>설명</dt>
      <dd>{description}</dd>
    </div>
    {
      responsibilities.length > 0 && (
        <div class="field-row">
          <dt>담당 업무</dt>
          <dd>
            <ul class="bullet-list">
              {responsibilities.map(r => (
                <li>{r}</li>
              ))}
            </ul>
          </dd>
        </div>
      )
    }
    {
      outcomes.length > 0 && (
        <div class="field-row">
          <dt>성과</dt>
          <dd>
            <ul class="bullet-list">
              {outcomes.map(o => (
                <li>{o}</li>
              ))}
            </ul>
          </dd>
        </div>
      )
    }
  </dl>

  {
    gallery.length > 0 && (
      <div class="card-links">
        <button
          type="button"
          class="related-link gallery-trigger"
          data-gallery-trigger
          data-gallery-images={JSON.stringify(gallery)}
          data-gallery-title={title}
        >
          📷 사진 보기 ({gallery.length})
        </button>
      </div>
    )
  }
</article>
