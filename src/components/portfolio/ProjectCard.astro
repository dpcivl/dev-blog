---
import type { CollectionEntry } from "astro:content";

type Props = {
  project: CollectionEntry<"portfolio">;
};

const { project } = Astro.props;
const {
  title,
  period,
  role,
  techStack,
  description,
  gallery,
  relatedPosts,
  links,
} = project.data;
const hasFooter =
  gallery.length > 0 ||
  relatedPosts.length > 0 ||
  !!links?.github ||
  !!links?.demo;
---

<article class="card">
  <h3 class="text-xl font-semibold mb-4">{title}</h3>

  <dl class="card-fields">
    <div class="field-row">
      <dt>기간</dt>
      <dd>{period}</dd>
    </div>
    {
      role && (
        <div class="field-row">
          <dt>역할</dt>
          <dd>{role}</dd>
        </div>
      )
    }
    {
      techStack.length > 0 && (
        <div class="field-row">
          <dt>기술 스택</dt>
          <dd>
            {techStack.map(t => <span class="tech-badge">{t}</span>)}
          </dd>
        </div>
      )
    }
    <div class="field-row">
      <dt>설명</dt>
      <dd>{description}</dd>
    </div>
  </dl>

  {
    hasFooter && (
      <div class="card-links">
        {gallery.length > 0 && (
          <button
            type="button"
            class="related-link gallery-trigger"
            data-gallery-trigger
            data-gallery-images={JSON.stringify(gallery)}
            data-gallery-title={title}
          >
            📷 사진 보기 ({gallery.length})
          </button>
        )}
        {relatedPosts.map(slug => (
          <a class="related-link" href={`/posts/${slug}`}>
            관련 글 →
          </a>
        ))}
        {links?.github && (
          <a
            class="related-link"
            href={links.github}
            target="_blank"
            rel="noopener noreferrer"
          >
            GitHub →
          </a>
        )}
        {links?.demo && (
          <a
            class="related-link"
            href={links.demo}
            target="_blank"
            rel="noopener noreferrer"
          >
            Live →
          </a>
        )}
      </div>
    )
  }
</article>
