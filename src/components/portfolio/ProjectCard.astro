---
import type { CollectionEntry } from "astro:content";

type Props = {
  project: CollectionEntry<"portfolio">;
};

const { project } = Astro.props;
const {
  title,
  period,
  role,
  techStack,
  description,
  cover,
  relatedPosts,
  links,
} = project.data;
---

<article class="card">
  {
    cover && typeof cover === "string" && (
      <img src={cover} alt={title} class="card-cover" loading="lazy" />
    )
  }
  <h3 class="text-xl font-semibold mb-1">{title}</h3>
  <div class="meta">
    <span>{period}</span>
    {role && <><span class="meta-sep">·</span><span>{role}</span></>}
  </div>
  {
    techStack.length > 0 && (
      <div class="mb-2">
        {techStack.map(t => <span class="tech-badge">{t}</span>)}
      </div>
    )
  }
  <p class="mb-2">{description}</p>
  <div class="flex flex-wrap items-center">
    {
      relatedPosts.map(slug => (
        <a class="related-link" href={`/posts/${slug}`}>
          관련 글 →
        </a>
      ))
    }
    {
      links?.github && (
        <a
          class="related-link"
          href={links.github}
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub →
        </a>
      )
    }
    {
      links?.demo && (
        <a
          class="related-link"
          href={links.demo}
          target="_blank"
          rel="noopener noreferrer"
        >
          Live →
        </a>
      )
    }
  </div>
</article>
