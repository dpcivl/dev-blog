---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Sidebar from "@/components/Sidebar.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { filterByLang } from "@/utils/i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = filterByLang(await getCollection("blog"), "en");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <div class="page-shell page-grid">
    <Sidebar />
    <main id="main-content" data-layout="index">
      {
        sortedPosts.length === 0 && (
          <section class="pt-8 pb-8">
            <h1 class="text-2xl font-semibold tracking-wide mb-2">
              English translations coming soon
            </h1>
            <p class="text-muted-foreground leading-7">
              I'm translating my Korean posts to English. Meanwhile, feel free
              to browse the{" "}
              <a class="underline" href="/">
                Korean version
              </a>{" "}
              — most posts include code, diagrams, and screenshots that are
              language-independent.
            </p>
          </section>
        )
      }

      {
        featuredPosts.length > 0 && (
          <section
            id="featured"
            class:list={[
              "pt-6 pb-6 md:pt-8",
              { "border-b border-border": recentPosts.length > 0 },
            ]}
          >
            <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
            <ul>
              {featuredPosts.map(
                (data, index) =>
                  index < SITE.featuredPostsPerIndex && (
                    <Card variant="h3" {...data} />
                  )
              )}
            </ul>
          </section>
        )
      }

      {
        recentPosts.length > 0 && (
          <section id="recent-posts" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
            <ul>
              {recentPosts.map(
                (data, index) =>
                  index < SITE.postPerIndex && <Card variant="h3" {...data} />
              )}
            </ul>
          </section>
        )
      }

      {
        sortedPosts.length > 0 && (
          <div class="my-8 text-center">
            <LinkButton href="/en/posts/">
              All Posts
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        )
      }
    </main>
  </div>
  <Footer />
</Layout>
