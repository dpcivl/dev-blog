*.css         text eol=lf
*.scss        text eol=lf
*.html        text eol=lf
*.svg         text eol=lf
*.xml         text eol=lf
*.txt         text eol=lf
*.sh          text eol=lf
Dockerfile    text eol=lf
.editorconfig text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf

